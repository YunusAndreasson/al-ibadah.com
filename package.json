{
  "name": "al-ibadah",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate": "tsx scripts/validate-content.ts",
    "validate:terms": "tsx scripts/validate-arabic-terms.ts",
    "build": "pnpm validate && pnpm validate:terms && astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "extract:glossary": "tsx scripts/extract-glossary-definitions.ts",
    "find:undefined-terms": "tsx scripts/find-undefined-terms.ts",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name al-ibadah --branch main --commit-dirty=true",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/amiri": "^5.2.8",
    "astro": "^5.17.2",
    "hijri-rrule": "^1.0.4",
    "preact": "^10.28.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@biomejs/biome": "^2.4.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.2.3",
    "gray-matter": "^4.0.3",
    "knip": "^5.83.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-smartypants": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.65.0"
  }
}
