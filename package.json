{
  "name": "al-ibadah",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "validate": "tsx scripts/validate-content.ts",
    "build:content": "tsx scripts/build-content.ts",
    "build": "pnpm validate && pnpm build:content && vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "migrate:citations": "tsx scripts/migrate-citations.ts",
    "migrate:citations:dry": "tsx scripts/migrate-citations.ts --dry-run",
    "fix:blockquotes": "tsx scripts/fix-blockquotes.ts",
    "fix:blockquotes:dry": "tsx scripts/fix-blockquotes.ts --dry-run",
    "fix:footnotes": "tsx scripts/fix-footnotes.ts",
    "fix:footnotes:dry": "tsx scripts/fix-footnotes.ts --dry-run",
    "extract:glossary": "tsx scripts/extract-glossary-definitions.ts",
    "migrate:glossary": "tsx scripts/migrate-glossary-terms.ts",
    "migrate:glossary:dry": "tsx scripts/migrate-glossary-terms.ts --dry-run",
    "find:undefined-terms": "tsx scripts/find-undefined-terms.ts",
    "deploy": "pnpm build && wrangler pages deploy .output"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.153.1",
    "@tanstack/react-start": "^1.153.1",
    "hijri-rrule": "^1.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "gray-matter": "^4.0.3",
    "nitro": "npm:nitro-nightly@3.0.1-20260113-190618-a765d98d",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "wrangler": "^4.59.2"
  }
}
