{
  "name": "al-ibadah",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate": "tsx scripts/validate-content.ts",
    "validate:terms": "tsx scripts/validate-arabic-terms.ts",
    "build": "pnpm generate:redirects && pnpm validate && pnpm validate:terms && astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "extract:glossary": "tsx scripts/extract-glossary-definitions.ts",
    "generate:redirects": "tsx scripts/generate-legacy-redirects.ts",
    "find:undefined-terms": "tsx scripts/find-undefined-terms.ts",
    "export:r2": "tsx scripts/export-to-r2.ts",
    "upload:items": "bash scripts/upload-items.sh",
    "pdf": "tsx scripts/generate-pdf.ts",
    "deploy": "pnpm build && pnpm pdf && wrangler pages deploy dist --project-name al-ibadah --branch main --commit-dirty=true",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/amiri": "^5.2.8",
    "astro": "^6.3.7",
    "hijri-rrule": "^1.0.4",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "gray-matter": "^4.0.3",
    "knip": "^6.14.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-smartypants": "^3.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.94.0"
  }
}
