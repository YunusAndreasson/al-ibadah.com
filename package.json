{
  "name": "al-ibadah",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "validate": "tsx scripts/validate-content.ts",
    "build:content": "tsx scripts/build-content.ts",
    "build": "pnpm validate && pnpm build:content && vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
