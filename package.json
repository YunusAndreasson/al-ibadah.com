{
  "name": "al-ibadah",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate": "tsx scripts/validate-content.ts",
    "build": "pnpm validate && astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "migrate:citations": "tsx scripts/migrate-citations.ts",
    "migrate:citations:dry": "tsx scripts/migrate-citations.ts --dry-run",
    "fix:blockquotes": "tsx scripts/fix-blockquotes.ts",
    "fix:blockquotes:dry": "tsx scripts/fix-blockquotes.ts --dry-run",
    "fix:footnotes": "tsx scripts/fix-footnotes.ts",
    "fix:footnotes:dry": "tsx scripts/fix-footnotes.ts --dry-run",
    "extract:glossary": "tsx scripts/extract-glossary-definitions.ts",
    "migrate:glossary": "tsx scripts/migrate-glossary-terms.ts",
    "migrate:glossary:dry": "tsx scripts/migrate-glossary-terms.ts --dry-run",
    "find:undefined-terms": "tsx scripts/find-undefined-terms.ts",
    "deploy": "pnpm build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/amiri": "^5.2.8",
    "astro": "^5.17.1",
    "hijri-rrule": "^1.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@tailwindcss/vite": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "gray-matter": "^4.0.3",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-smartypants": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.63.0"
  }
}
