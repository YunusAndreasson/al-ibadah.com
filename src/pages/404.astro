---
import PageLayout from '~/components/layout/PageLayout.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CATEGORY_NAMES } from '~/lib/content-utils'
---

<BaseLayout title="Sidan hittades inte - al-Ibadah">
  <PageLayout>
    <div class="flex min-h-[50vh] flex-col items-center justify-center">
      <h1 class="text-2xl font-bold text-foreground">Sidan hittades inte</h1>
      <p class="mt-2 text-muted-foreground">Sidan du söker finns inte eller har flyttats.</p>
      <a href="/" class="mt-4 text-primary hover:underline">
        Tillbaka till startsidan
      </a>

      <div class="mt-10 w-full max-w-md">
        <h2 class="text-lg font-semibold text-foreground mb-4 text-center">Kategorier</h2>
        <div class="grid grid-cols-2 gap-3">
          {Object.entries(CATEGORY_NAMES).map(([slug, name]) => (
            <a href={`/${slug}`} class="card text-center py-3">
              {name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </PageLayout>
</BaseLayout>
