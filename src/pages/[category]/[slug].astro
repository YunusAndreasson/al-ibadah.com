---
import { getCollection, render } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import PageLayout from '~/components/layout/PageLayout.astro'
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro'
import ArticleRenderer from '~/components/content/ArticleRenderer.astro'
import { CATEGORY_NAMES } from '~/lib/content-utils'
import {
  buildBreadcrumbSchema,
  buildFAQPageSchema,
  buildArticleSchema,
  extractQA,
} from '~/lib/structured-data'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles
    .filter((a) => a.id.split('/').length === 2)
    .map((article) => {
      const [category, slug] = article.id.split('/')
      return {
        params: { category, slug },
        props: { article },
      }
    })
}

const { category } = Astro.params
const { article } = Astro.props
const { Content } = await render(article)
const categoryName = CATEGORY_NAMES[category!] || category
const pageUrl = `/${category}/${Astro.params.slug}`
const breadcrumbItems = [
  { label: 'Hem', href: '/' },
  { label: categoryName!, href: `/${category}` },
  { label: article.data.title, href: pageUrl },
]
const qa = extractQA(article.body)
const articleSchema = qa
  ? buildFAQPageSchema({
      title: article.data.title,
      description: article.data.description,
      url: pageUrl,
      question: qa.question,
      answer: qa.answer,
      author: article.data.author,
    })
  : buildArticleSchema({
      title: article.data.title,
      description: article.data.description,
      url: pageUrl,
      author: article.data.author,
    })
const jsonLd = [buildBreadcrumbSchema(breadcrumbItems), articleSchema]
---

<BaseLayout
  title={`${article.data.title} - al-Ibadah`}
  description={article.data.description}
  article
  author={article.data.author}
  jsonLd={jsonLd}
>
  <PageLayout>
    <Breadcrumbs
      items={[
        { label: 'Hem', href: '/' },
        { label: categoryName!, href: `/${category}` },
      ]}
    />

    <ArticleRenderer
      title={article.data.title}
      author={article.data.author}
      source={article.data.source}
    >
      <Content />
    </ArticleRenderer>
  </PageLayout>
</BaseLayout>
