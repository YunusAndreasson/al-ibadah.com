---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import ArticleRenderer from '~/components/content/ArticleRenderer.astro'
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro'
import PageLayout from '~/components/layout/PageLayout.astro'
import { entityByBioSlug } from '~/data/authors'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CATEGORY_NAMES } from '~/lib/content-utils'
import { getRelatedArticles, type RelatedArticle } from '~/lib/related-articles'
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildFAQPageSchema,
  buildPersonSchema,
  extractQA,
} from '~/lib/structured-data'

export async function getStaticPaths() {
  const articles: CollectionEntry<'articles'>[] = await getCollection('articles')
  const categoryArticles = articles.filter((a) => a.id.split('/').length === 2)
  return categoryArticles.map((article) => {
    const [category, slug] = article.id.split('/')
    return {
      params: { category, slug },
      props: { article, relatedArticles: getRelatedArticles(article.id, articles) },
    }
  })
}

interface Props {
  article: CollectionEntry<'articles'>
  relatedArticles: RelatedArticle[]
}

const { category, slug } = Astro.params
const { article, relatedArticles } = Astro.props
const { Content } = await render(article)
const categoryName = CATEGORY_NAMES[category!] || category
const pageUrl = `/${category}/${slug}`
const breadcrumbItems = [
  { label: 'Hem', href: '/' },
  { label: categoryName!, href: `/${category}` },
  { label: article.data.title, href: pageUrl },
]
const qa = extractQA(article.body)
const articleSchema = qa
  ? buildFAQPageSchema({
      title: article.data.title,
      description: article.data.description,
      url: pageUrl,
      question: qa.question,
      answer: qa.answer,
      author: article.data.author,
      source: article.data.source,
    })
  : buildArticleSchema({
      title: article.data.title,
      description: article.data.description,
      url: pageUrl,
      author: article.data.author,
      source: article.data.source,
    })
// Biography pages describe a scholar — emit a Person/Organization entity (with
// verified sameAs) instead of Article, so they anchor the site's author authority.
const bioEntity = category === 'biografier' ? entityByBioSlug(slug!) : undefined
const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  bioEntity ? buildPersonSchema(bioEntity) : articleSchema,
]
---

<BaseLayout
  title={`${article.data.title} - al-Ibadah`}
  description={article.data.description}
  article
  author={article.data.author}
  jsonLd={jsonLd}
>
  <PageLayout>
    <Breadcrumbs
      items={[
        { label: 'Hem', href: '/' },
        { label: categoryName!, href: `/${category}` },
      ]}
    />

    <ArticleRenderer
      title={article.data.title}
      author={article.data.author}
      source={article.data.source}
      category={categoryName}
      relatedArticles={relatedArticles}
    >
      <Content />
    </ArticleRenderer>
  </PageLayout>
</BaseLayout>
