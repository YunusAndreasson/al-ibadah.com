---
import { getCollection } from 'astro:content'
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro'
import PageLayout from '~/components/layout/PageLayout.astro'
import SubcategoryName from '~/components/ui/SubcategoryName.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CATEGORY_NAMES, deriveSubcategoryName } from '~/lib/content-utils'
import { renderTitle } from '~/lib/render-title'
import { buildBreadcrumbSchema, buildCollectionPageSchema } from '~/lib/structured-data'

export async function getStaticPaths() {
  const articles = await getCollection('articles')

  // Group articles by category/subcategory
  const subcategoryMap = new Map<
    string,
    {
      category: string
      subcategory: string
      categoryName: string
      subcategoryName: string
      articles: Array<{ slug: string; title: string; author?: string }>
    }
  >()

  for (const article of articles) {
    const segments = article.id.split('/')
    if (segments.length !== 3) continue

    const [category, subcategory, slug] = segments
    const key = `${category}/${subcategory}`

    if (!subcategoryMap.has(key)) {
      subcategoryMap.set(key, {
        category,
        subcategory,
        categoryName: CATEGORY_NAMES[category] || category,
        subcategoryName: deriveSubcategoryName(article.data.categories, subcategory),
        articles: [],
      })
    }

    subcategoryMap.get(key)!.articles.push({
      slug,
      title: article.data.title,
      author: article.data.author,
    })
  }

  return Array.from(subcategoryMap.values()).map((data) => ({
    params: { category: data.category, subcategory: data.subcategory },
    props: {
      categoryName: data.categoryName,
      subcategoryName: data.subcategoryName,
      articles: data.articles.sort((a, b) => a.title.localeCompare(b.title, 'sv')),
    },
  }))
}

const { category, subcategory } = Astro.params
const { categoryName, subcategoryName, articles } = Astro.props
const subcategoryDescription = `${articles.length} utlåtanden om ${subcategoryName.toLowerCase()} inom ${categoryName.toLowerCase()}.`
const breadcrumbItems = [
  { label: 'Hem', href: '/' },
  { label: categoryName, href: `/${category}` },
  { label: subcategoryName, href: `/${category}/${subcategory}` },
]
const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  buildCollectionPageSchema({
    title: subcategoryName,
    description: subcategoryDescription,
    url: `/${category}/${subcategory}`,
    itemCount: articles.length,
  }),
]
---

<BaseLayout title={`${subcategoryName} - al-Ibadah`} description={subcategoryDescription} jsonLd={jsonLd}>
  <PageLayout>
    <Breadcrumbs
      items={[
        { label: 'Hem', href: '/' },
        { label: categoryName, href: `/${category}` },
      ]}
    />

    <SubcategoryName name={subcategoryName} variant="title" />

    {articles.length > 0 ? (
      <div class="grid gap-3">
        {articles.map((article: { slug: string; title: string; author?: string }, i: number) => (
          <a
            href={`/${category}/${subcategory}/${article.slug}`}
            class="card block animate-fade-up"
            style={`animation-delay: ${(i + 1) * 40}ms`}
          >
            <h2 class="font-medium mb-1 text-foreground" set:html={renderTitle(article.title)} />
            {article.author && <p class="text-sm text-muted-foreground">{article.author}</p>}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground">Inga artiklar i denna underkategori.</p>
    )}
  </PageLayout>
</BaseLayout>
