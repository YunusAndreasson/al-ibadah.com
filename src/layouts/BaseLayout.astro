---
import { ClientRouter } from 'astro:transitions'
import '@fontsource-variable/inter'
import '@fontsource-variable/source-serif-4'
import '@fontsource-variable/source-serif-4/wght-italic.css'
import '@fontsource/amiri/400.css'
import '@fontsource/amiri/400-italic.css'
import '@fontsource/amiri/700.css'
import '~/styles/app.css'
import JsonLd from '~/components/seo/JsonLd.astro'

interface Props {
  title?: string
  description?: string
  article?: boolean
  author?: string
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>
}

const {
  title = 'al-Ibadah - Islamisk kunskapssamling',
  description = 'En kunskapssamling om islamisk dyrkan och teologi på svenska.',
  article = false,
  author,
  jsonLd,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImageURL = new URL('/og-image.png', Astro.site)
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="al-Ibadah" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta name="theme-color" id="theme-color" content="#f9f4ee" />

    {author && <meta name="author" content={author} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="al-Ibadah" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {jsonLd && <JsonLd data={jsonLd} />}

    <script is:inline>
      (function(){
        function apply(doc){
          var t=localStorage.getItem("theme")||"system",d=t==="dark"||t==="system"&&matchMedia("(prefers-color-scheme:dark)").matches;
          doc.documentElement.classList.toggle("dark",d);
          doc.documentElement.style.colorScheme=d?"dark":"light";
          var m=doc.getElementById("theme-color");
          if(m)m.setAttribute("content",d?"#1c1410":"#f9f4ee");
        }
        apply(document);
        document.addEventListener("astro:before-swap",function(e){apply(e.newDocument)});
        document.addEventListener("astro:after-swap",function(){apply(document)})
      })()
    </script>

    <ClientRouter />
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen">
    <slot />

    <script>
      function initFootnoteTooltips() {
        const container = document.querySelector('.prose-reading')
        if (!container) return

        const footnoteRefs = container.querySelectorAll('a[data-footnote-ref]')
        if (footnoteRefs.length === 0) return

        const footnoteTexts = new Map<string, string>()
        container.querySelectorAll('li[id^="user-content-fn-"]').forEach((li) => {
          const clone = li.cloneNode(true) as HTMLElement
          clone.querySelectorAll('a[data-footnote-backref]').forEach((el) => el.remove())
          footnoteTexts.set(li.id, clone.textContent?.trim() || '')
        })

        footnoteRefs.forEach((ref) => {
          const href = ref.getAttribute('href')
          if (!href) return
          const footnoteId = href.replace('#', '')
          const text = footnoteTexts.get(footnoteId)
          if (text) ref.setAttribute('data-tooltip', text)
        })
      }

      function initTooltips() {
        ;(window as any).__tooltipCleanup?.()
        document.getElementById('prose-tooltip')?.remove()

        const tooltip = document.createElement('div')
        tooltip.id = 'prose-tooltip'
        tooltip.className = 'prose-tooltip'
        tooltip.setAttribute('role', 'tooltip')
        document.body.appendChild(tooltip)

        let activeTarget: Element | null = null
        const hasHover = window.matchMedia('(hover: hover)').matches
        const ac = new AbortController()

        function show(target: Element) {
          const text = target.getAttribute('data-definition') || target.getAttribute('data-tooltip')
          if (!text) return

          tooltip.textContent = text
          tooltip.style.display = 'block'
          activeTarget = target

          const rect = target.getBoundingClientRect()
          const tipRect = tooltip.getBoundingClientRect()

          let top = rect.top - tipRect.height - 8
          let left = rect.left

          // Clamp to right edge
          if (left + tipRect.width > window.innerWidth - 8) {
            left = window.innerWidth - tipRect.width - 8
          }
          // Clamp to left edge
          if (left < 8) left = 8
          // If above viewport, show below instead
          if (top < 8) top = rect.bottom + 8

          tooltip.style.top = `${top}px`
          tooltip.style.left = `${left}px`
        }

        function hide() {
          tooltip.style.display = 'none'
          activeTarget = null
        }

        const sel = '.glossary-term, sup a[data-footnote-ref][data-tooltip]'

        // Desktop: hover
        if (hasHover) {
          document.addEventListener('mouseover', (e) => {
            const t = (e.target as Element).closest(sel)
            if (t) show(t)
          }, { signal: ac.signal })

          document.addEventListener('mouseout', (e) => {
            const t = (e.target as Element).closest(sel)
            if (!t) return
            const rel = (e as MouseEvent).relatedTarget as Node | null
            if (!rel || !t.contains(rel)) hide()
          }, { signal: ac.signal })
        }

        // Tap (touch devices + desktop click fallback)
        document.addEventListener('click', (e) => {
          const t = (e.target as Element).closest(sel)
          if (t) {
            if (!hasHover && t.matches('a[data-footnote-ref]')) e.preventDefault()
            if (activeTarget === t) hide()
            else show(t)
          } else if (activeTarget) {
            hide()
          }
        }, { signal: ac.signal })

        // Dismiss on scroll
        window.addEventListener('scroll', hide, { passive: true, signal: ac.signal })

        ;(window as any).__tooltipCleanup = () => ac.abort()
      }

      initFootnoteTooltips()
      initTooltips()
      document.addEventListener('astro:after-swap', () => {
        initFootnoteTooltips()
        initTooltips()
      })
    </script>
  </body>
</html>
