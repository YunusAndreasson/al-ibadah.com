---
import { MobileMenu } from '~/components/ui/MobileMenu'
import { SearchIsland } from '~/components/ui/SearchIsland'
import { ThemeToggle } from '~/components/ui/ThemeToggle'

const navLinks = [
  { href: '/troslara', label: 'Troslära' },
  { href: '/renhet', label: 'Renhet' },
  { href: '/bon', label: 'Bön' },
  { href: '/allmosa', label: 'Allmosa' },
  { href: '/fasta', label: 'Fasta' },
  { href: '/vallfard', label: 'Vallfärd' },
  { href: '/blandat', label: 'Blandat' },
]

const footerLinks = [
  { href: '/om', label: 'Om webbplatsen' },
  { href: '/termer', label: 'Ordlista' },
  { href: '/biografier', label: 'Biografier' },
  { href: '/rss.xml', label: 'RSS' },
]

const currentPath = Astro.url.pathname
---

<a href="#main" class="skip-link">
  Hoppa till huvudinnehåll
</a>

<header class="sticky top-0 z-30 bg-background/80 backdrop-blur-lg pt-[env(safe-area-inset-top)]">
  <div class="max-w-3xl mx-auto px-4 h-14 flex items-center justify-between safe-x">
    <a href="/" class="font-semibold tracking-tight text-foreground">
      al-Ibadah
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Huvudnavigering">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link text-sm font-medium px-2.5 py-1.5 rounded-lg hover-bg', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <SearchIsland client:load transition:persist />
      <ThemeToggle client:load transition:persist />
      <MobileMenu client:load navLinks={navLinks} footerLinks={footerLinks} currentPath={currentPath} />
    </div>
  </div>
</header>
