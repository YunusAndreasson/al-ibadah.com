<div class="fixed bottom-[calc(1.5rem+env(safe-area-inset-bottom))] right-[calc(1.5rem+env(safe-area-inset-right))] z-40 flex items-center gap-2">
  <button
    id="share-fixed"
    type="button"
    class="p-2.5 rounded-full bg-muted/80 text-muted-foreground hover:text-foreground shadow-sm border border-border/50 opacity-0 pointer-events-none transition-all duration-200 press-scale cursor-pointer"
    aria-label="Dela"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
      <polyline points="16 6 12 2 8 6" />
      <line x1="12" x2="12" y1="2" y2="15" />
    </svg>
  </button>
  <button
    id="scroll-to-top"
    type="button"
    class="p-2.5 rounded-full bg-muted/80 text-muted-foreground hover:text-foreground shadow-sm border border-border/50 opacity-0 pointer-events-none transition-all duration-200 press-scale cursor-pointer"
    aria-label="Tillbaka till toppen"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m18 15-6-6-6 6" />
    </svg>
  </button>
</div>

<script>
  function initFixedButtons() {
    const scrollBtn = document.getElementById('scroll-to-top')
    const shareBtn = document.getElementById('share-fixed')

    const isArticle = !!document.querySelector('.prose-reading')

    if (scrollBtn) {
      const show = () => {
        scrollBtn.classList.remove('opacity-0', 'pointer-events-none')
        if (shareBtn && isArticle) shareBtn.classList.remove('opacity-0', 'pointer-events-none')
      }
      const hide = () => {
        scrollBtn.classList.add('opacity-0', 'pointer-events-none')
        if (shareBtn) shareBtn.classList.add('opacity-0', 'pointer-events-none')
      }

      window.addEventListener(
        'scroll',
        () => {
          if (window.scrollY > 400) show()
          else hide()
        },
        { passive: true },
      )

      scrollBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })
    }

    if (shareBtn && isArticle) {
      shareBtn.addEventListener('click', async () => {
        const title = document.title
        const url = window.location.href
        if (navigator.share) {
          try {
            await navigator.share({ title, url })
          } catch (err) {
            if ((err as Error).name !== 'AbortError') {
              await navigator.clipboard.writeText(url)
            }
          }
        } else {
          await navigator.clipboard.writeText(url)
        }
      })
    }
  }

  initFixedButtons()
  document.addEventListener('astro:after-swap', initFixedButtons)
</script>
