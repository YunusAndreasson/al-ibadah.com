<button
  id="scroll-to-top"
  type="button"
  class="fixed bottom-[calc(1.5rem+env(safe-area-inset-bottom))] right-[calc(1.5rem+env(safe-area-inset-right))] z-40 p-2.5 rounded-full bg-muted/80 text-muted-foreground shadow-sm border border-border/50 opacity-0 pointer-events-none transition-opacity duration-200 press-scale"
  aria-label="Tillbaka till toppen"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="m18 15-6-6-6 6" />
  </svg>
</button>

<script>
  function initScrollToTop() {
    const btn = document.getElementById('scroll-to-top')
    if (!btn) return

    const show = () => {
      btn.classList.remove('opacity-0', 'pointer-events-none')
    }
    const hide = () => {
      btn.classList.add('opacity-0', 'pointer-events-none')
    }

    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 400) show()
        else hide()
      },
      { passive: true },
    )

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  }

  initScrollToTop()
  document.addEventListener('astro:after-swap', initScrollToTop)
</script>
