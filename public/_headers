# Cloudflare Pages Headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# NOTE: Cloudflare combines (concatenates) headers from every matching rule, so
# Cache-Control must NOT be set on overlapping paths. The catch-all /* therefore
# carries only security headers; HTML keeps Cloudflare Pages' default
# `public, max-age=0, must-revalidate`, while hashed assets opt into immutable
# caching below.

# Hashed build assets (Astro JS/CSS/fonts) - cache for 1 year (immutable)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static fonts in public/fonts - cache for 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Security headers for all responses (no Cache-Control here - see note above)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
