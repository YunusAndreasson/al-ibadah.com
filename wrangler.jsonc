{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "al-ibadah",
  "compatibility_date": "2025-01-01",
  "pages_build_output_dir": "dist",
  // Pages config does not support the dedicated `ai_search` binding (Workers
  // only). We reach the AI Search instance `al-ibadah-search` through the
  // Workers AI binding instead — see functions/api/search.ts (env.AI.autorag).
  "ai": {
    "binding": "AI"
  }
}
